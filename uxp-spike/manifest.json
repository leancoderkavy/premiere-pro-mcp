{
  "manifestVersion": 5,
  "id": "com.mcp.premiere.uxp.spike",
  "name": "MCP UXP Spike",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "spikePanel",
      "label": { "default": "MCP UXP Spike" },
      "minimumSize": { "width": 380, "height": 480 },
      "preferredDockedSize": { "width": 420, "height": 640 },
      "preferredFloatingSize": { "width": 480, "height": 700 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": "all"
    }
  }
}
